# =============================================================================
# FlyPaper — .gitignore (DevSecOps hardening)
# Plantilla de entorno permitida: .env.example (sin secretos reales)
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Archivos de entorno local con credenciales (CRÍTICO)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env
secrets.json
*.pem
*.key
credentials.json
credentials.*.json

# -----------------------------------------------------------------------------
# 2. Bases de datos SQLite — NUNCA versionar persistencia
# -----------------------------------------------------------------------------
# Ignorar directorio de datos unificado (Bases de datos de producción y CTF)
data/
data/**/*.db

# Por seguridad, ignorar cualquier base de datos residual en la raíz
*.db

# Variantes y artefactos SQLite
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# Nombres canónicos (defensa en profundidad en cualquier ruta)
flypaper.db
flypaper_priv.db
flypaper_autoban.db
flypaper_users.db
ip_cache.db
**/flypaper.db
**/flypaper_priv.db
**/flypaper_autoban.db
**/flypaper_users.db
**/ip_cache.db
**/sqli_*.db

# -----------------------------------------------------------------------------
# 3. Cachés de Python y carpetas del sistema
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Entornos virtuales
.venv/
venv/
env/

# Herramientas de desarrollo y calidad
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/
.tox/
.nox/

# Empaquetado y distribución
*.egg-info/
dist/
build/
*.egg

# -----------------------------------------------------------------------------
# 4. Docker e infraestructura local
# -----------------------------------------------------------------------------
docker_data/
*.override.yml

# -----------------------------------------------------------------------------
# 5. Logs y artefactos de ejecución
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# 6. IDEs, editores y sistema operativo
# -----------------------------------------------------------------------------
.vscode/
.idea/
.cursor/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# 7. Jupyter y notebooks locales
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# 8. Código legacy / respaldos locales
# -----------------------------------------------------------------------------
*_old.py
*_Old.py

# -----------------------------------------------------------------------------
# 9. Documentación interna (no publicar)
# -----------------------------------------------------------------------------
informe/
informe/desarrollo.md
informe/despliegue.md
