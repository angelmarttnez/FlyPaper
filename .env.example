# Copia este archivo a .env y rellena los valores (nunca subas .env a git).

# IA
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Telegram — grupo con Topics (message_thread_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_LOGINS=
TELEGRAM_TOPIC_ATAQUES=
TELEGRAM_TOPIC_RESUMEN=

# Reputación IP perimetral (AbuseIPDB + VirusTotal + ip-api sin key)
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
SCORE_THRESHOLD=50.0

# Super-administradores SOC (bootstrap flypaper_priv.db — contraseñas iniciales, bcrypt)
INITIAL_ADMIN_ANGEL_PASSWORD=
INITIAL_ADMIN_CARLOS_PASSWORD=
