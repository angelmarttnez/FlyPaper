# Copia este archivo a .env y rellena los valores (nunca subas .env a git).

# IA
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Telegram — grupo con Topics (message_thread_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_LOGINS=
TELEGRAM_TOPIC_ATAQUES=
TELEGRAM_TOPIC_RESUMEN=

# Reputación IP perimetral (AbuseIPDB + VirusTotal + ip-api sin key)
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
SCORE_THRESHOLD=50.0

# Perímetro NGWAF (Redis) — en Docker Compose se inyecta redis://redis:6379/0
REDIS_URL=redis://127.0.0.1:6379/0
RATE_LIMIT_MAX_REQ=60
RATE_LIMIT_WINDOW_SEC=60
RISK_SCORE_AUTOBAN=5
REDIS_BLOCK_TTL=86400
CIRCUIT_BREAKER_FAILS=3
CIRCUIT_BREAKER_OPEN_SEC=3600

# Directorio de datos SQLite (opcional; por defecto ./data en la raíz del repo)
# En Docker Compose se fuerza a /app/data con volumen ./data:/app/data
# FLYPAPER_DATA_DIR=

# Super-administradores SOC (bootstrap flypaper_priv.db — contraseñas iniciales, bcrypt)
INITIAL_ADMIN_ANGEL_PASSWORD=
INITIAL_ADMIN_CARLOS_PASSWORD=
